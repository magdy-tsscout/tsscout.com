<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect www to non-www (optional if needed)
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

    # Redirect domainName/public/ to root domain without /public
    RewriteCond %{REQUEST_URI} ^/public/?$ [NC]
    RewriteRule ^public/?$ / [L,R=301]

    # Redirect /public/somepage to /somepage
    RewriteCond %{REQUEST_URI} ^/public/(.*)$ [NC]
    RewriteRule ^public/(.*)$ /$1 [L,R=301]

    # Canonicalize image requests so SVG assets are always served from /public/images.
    RewriteRule ^images/(.*)$ /public/images/$1 [L,R=301]

    # Handle Trailing Slashes (if not a directory)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Send Requests to index.php (Laravel)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]

    <Files .env>
    Order Allow,Deny
    Deny from all
</Files>


</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.svg$">
        Header always unset Cache-Control
        Header always set Cache-Control "public, max-age=31536000, s-maxage=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(?:css|js|mjs|ico|webp|png|jpe?g|woff2?|ttf|otf)$">
        Header always unset Cache-Control
        Header always set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
