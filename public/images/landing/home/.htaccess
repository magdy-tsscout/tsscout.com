<IfModule mod_headers.c>
    <FilesMatch "\.svg$">
        Header always unset Cache-Control
        Header always set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>
